import { useState } from "react"; import { Card, CardContent } from "@/components/ui/card"; import { Button } from "@/components/ui/button"; import { Input } from "@/components/ui/input"; import { Textarea } from "@/components/ui/textarea"; import { motion } from "framer-motion";

export default function AIVideoSite(){ const [idea,setIdea]=useState(""); const [script,setScript]=useState(""); const [video,setVideo]=useState(null);

const generateScript=()=>{ if(!idea) return;

const generated=`Hook: Did you know about ${idea}?\n\nScene 1: Introduce the topic quickly.\nScene 2: Explain something surprising.\nScene 3: Give value or a fact.\n\nCall to action: Follow for more.`;

setScript(generated);

};

const generateVideo=()=>{ const fakeVideo="https://samplelib.com/lib/preview/mp4/sample-5s.mp4"; setVideo(fakeVideo); };

return ( <div className="min-h-screen p-10 grid gap-8 bg-gray-50">

<motion.h1
    initial={{opacity:0,y:-20}}
    animate={{opacity:1,y:0}}
    className="text-3xl font-bold"
  >
    AI Viral Video Generator
  </motion.h1>

  <Card className="rounded-2xl shadow-lg">
    <CardContent className="p-6 grid gap-4">

      <h2 className="text-xl font-semibold">1. Video Idea</h2>

      <Input
        placeholder="Enter a topic (history facts, football, money tips...)"
        value={idea}
        onChange={(e)=>setIdea(e.target.value)}
      />

      <Button onClick={generateScript}>Generate Script</Button>

    </CardContent>
  </Card>

  <Card className="rounded-2xl shadow-lg">
    <CardContent className="p-6 grid gap-4">

      <h2 className="text-xl font-semibold">2. Script</h2>

      <Textarea
        value={script}
        onChange={(e)=>setScript(e.target.value)}
        rows={8}
      />

      <Button onClick={generateVideo}>Generate AI Video</Button>

    </CardContent>
  </Card>

  {video && (
    <Card className="rounded-2xl shadow-lg">
      <CardContent className="p-6 grid gap-4">

        <h2 className="text-xl font-semibold">3. Preview</h2>

        <video src={video} controls className="rounded-xl" />

        <Button>Download Video</Button>

      </CardContent>
    </Card>
  )}

  <Card className="rounded-2xl shadow-lg">
    <CardContent className="p-6 grid gap-4">

      <h2 className="text-xl font-semibold">Monetization Tools</h2>

      <ul className="list-disc ml-6 text-sm">
        <li>Auto short video format (9:16)</li>
        <li>Automatic captions</li>
        <li>Trending hashtag generator</li>
        <li>Batch video creation</li>
        <li>TikTok / Reels / Shorts ready export</li>
        <li>AI voiceover</li>
      </ul>

    </CardContent>
  </Card>

</div>

); }
